# Code Context Retrieval — Environment Configuration
# Copy this file to .env and fill in the values

# === Database ===
# PostgreSQL connection string for metadata storage
# Hint: Set DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Required by: All features
DATABASE_URL=

# === Cache & Broker ===
# Redis connection URL for Celery broker and query cache
# Hint: Set REDIS_URL=redis://localhost:6379/0
# Required by: All features
REDIS_URL=

# === Vector Store ===
# Qdrant URL for semantic search
# Hint: Set QDRANT_URL=http://localhost:6333
# Required by: Chunk indexing, semantic retrieval
QDRANT_URL=

# === Keyword Index ===
# Elasticsearch URL for keyword search
# Hint: Set ELASTICSEARCH_URL=http://localhost:9200
# Required by: Chunk indexing, keyword retrieval
ELASTICSEARCH_URL=

# === ML Models ===
# Embedding model name for semantic search (bge-code)
# Hint: Set EMBEDDING_MODEL=BAAI/bge-code-v1
# Required by: Embedding generation, semantic retrieval
EMBEDDING_MODEL=

# Reranker model name for neural reranking
# Hint: Set RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Required by: Neural reranking
RERANKER_MODEL=

# === Security ===
# Secret key for API key hashing
# Hint: Generate with: openssl rand -hex 32
# Required by: Authentication, MCP, Web UI
API_KEY_SECRET=

# === Optional ===
# Query service port (default: 8000)
# QUERY_SERVICE_PORT=8000

# Semantic similarity threshold (default: 0.6)
# SEMANTIC_THRESHOLD=0.6

# Index refresh schedule (crontab format, default weekly)
# INDEX_REFRESH_SCHEDULE=0 0 * * 0
