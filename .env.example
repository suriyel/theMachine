# Code Context Retrieval — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# PostgreSQL URL — connection string for repository metadata, API keys, job tracking
# Hint: Set to postgresql+asyncpg://user:pass@localhost:5432/codecontext
# Required by features: 1, 2, 3, 4, 16
DATABASE_URL=

# Elasticsearch URL — cluster URL for BM25 keyword search
# Hint: Set to http://localhost:9200
# Required by features: 8, 9, 10, 13, 14, 15, 17, 20
ELASTICSEARCH_URL=

# Qdrant URL — cluster URL for dense vector search
# Hint: Set to http://localhost:6333
# Required by features: 7, 9, 13, 14, 15, 17
QDRANT_URL=

# Redis URL — instance URL for query caching and rate limiting
# Hint: Set to redis://localhost:6379/0
# Required by features: 16, 25
REDIS_URL=

# RabbitMQ URL — broker URL for Celery task queue
# Hint: Set to amqp://guest:guest@localhost:5672//
# Required by features: 4, 21, 22
RABBITMQ_URL=

# Repository Clone Path — base directory for cloned Git repositories
# Hint: Set to /tmp/codecontext/repos or a persistent volume path
# Required by features: 4, 5
REPO_CLONE_PATH=

# API Secret Key — secret key for API key hashing and session signing
# Hint: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required by features: 16
SECRET_KEY=

# Query API Port — port for the FastAPI query service
# Hint: Set to 8000 (default)
# Required by features: 17
API_PORT=8000

# MCP Server Port — port for the MCP server
# Hint: Set to 3000 (default)
# Required by features: 18
MCP_PORT=3000
