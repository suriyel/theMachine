# Code Context Retrieval — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# PostgreSQL URL — connection string for repository metadata, API keys, job tracking
# Hint: Set to postgresql+asyncpg://user:pass@localhost:5432/codecontext
# Required by features: 1, 2, 3, 4, 16
DATABASE_URL=

# Elasticsearch URL — cluster URL for BM25 keyword search
# Hint: Set to http://localhost:9200
# Required by features: 8, 9, 10, 13, 14, 15, 17, 20
ELASTICSEARCH_URL=

# Qdrant URL — cluster URL for dense vector search
# Hint: Set to http://localhost:6333
# Required by features: 7, 9, 13, 14, 15, 17
QDRANT_URL=

# Redis URL — instance URL for query caching and rate limiting
# Hint: Set to redis://localhost:6379/0
# Required by features: 16, 25
REDIS_URL=

# RabbitMQ URL — broker URL for Celery task queue
# Hint: Set to amqp://guest:guest@localhost:5672//
# Required by features: 4, 21, 22
RABBITMQ_URL=

# Repository Clone Path — base directory for cloned Git repositories
# Hint: Set to /tmp/codecontext/repos or a persistent volume path
# Required by features: 4, 5
REPO_CLONE_PATH=

# API Secret Key — secret key for API key hashing and session signing
# Hint: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required by features: 16
SECRET_KEY=

# Query API Port — port for the FastAPI query service
# Hint: Set to 8000 (default)
# Required by features: 17
API_PORT=8000

# MCP Server Port — port for the MCP server
# Hint: Set to 3000 (default)
# Required by features: 18
MCP_PORT=3000
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Reranker Model — model name for neural reranking
# Hint: Set to qwen3-rerank
# Required by features: 11
RERANKER_MODEL=qwen3-rerank

# Reranker API Key — API key for DashScope reranker
# Hint: Same as EMBEDDING_API_KEY if using DashScope
# Required by features: 11
RERANKER_API_KEY=

# Reranker Base URL — base URL for reranker API
# Hint: Set to https://dashscope.aliyuncs.com/compatible-api/v1
# Required by features: 11
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# Reranker Threshold — minimum relevance score to keep a result
# Hint: Set to 0.3 (results below this score are filtered out)
# Required by features: 11
RERANKER_THRESHOLD=0.3

# MiniMax API Key — API key for MiniMax2.5 Code Plan LLM (evaluation annotation)
# Hint: Get from MiniMax console
# Required by features: 41
MINIMAX_API_KEY=

# MiniMax Base URL — base URL for MiniMax OpenAI-compatible API
# Hint: Set to https://api.minimax.chat/v1
# Required by features: 41
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# MiniMax Model — model name for evaluation annotation
# Hint: Set to MiniMax-M1-80k
# Required by features: 41
MINIMAX_MODEL=MiniMax-M1-80k

# Zhipu API Key — API key for Zhipu CodeGeeX LLM (evaluation annotation)
# Hint: Get from open.bigmodel.cn
# Required by features: 41
ZHIPU_API_KEY=

# Zhipu Base URL — base URL for Zhipu OpenAI-compatible API
# Hint: Set to https://open.bigmodel.cn/api/paas/v4
# Required by features: 41
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Zhipu Model — model name for Zhipu evaluation annotation
# Hint: Set to codegeex-4
# Required by features: 41
ZHIPU_MODEL=codegeex-4

# Eval LLM Provider — selects which LLM provider to use for evaluation
# Hint: Set to minimax or zhipu
# Required by features: 41
EVAL_LLM_PROVIDER=minimax
